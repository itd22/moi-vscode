{
    "python.formatting.provider": "autopep8",
    "python.linting.enabled": true,
    "python.linting.lintOnSave": true,
    "python.linting.pycodestyleArgs": [
        "--ignore=E302,W503",
        "C0116",
        "W1202",
        "--max-line-length=120",
        "--logging-format-style=fstr"
    ],
    "terminal.integrated.fontSize": 18,
    "editor.suggestFontSize": 10,
    "debug.console.fontSize": 10,
    "debug.console.lineHeight": 12,
    "terminal.integrated.rendererType": "dom",
    "workbench.colorTheme": "Night Owl",
    "diffEditor.ignoreTrimWhitespace": false,
    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "scope": "log.error",
                "settings": {
                    "foreground": "#af1f1f",
                    "fontStyle": "bold"
                }
            },
            {
                "scope": "log.warning",
                "settings": {
                    "foreground": "#f4ad42",
                    "fontStyle": ""
                }
            }
        ]
    },
    "workbench.iconTheme": "material-icon-theme",
    "editor.minimap.enabled": false,
    "explorer.openEditors.visible": 1,
    "workbench.settings.editor": "ui",
    "breadcrumbs.enabled": false,
    "workbench.colorCustomizations": {
        "activityBar.background": "#00AA00",
        "titleBar.activeBackground": "#eb5324",
        "titleBar.inactiveBackground": "#007fff99",
        "titleBar.activeForeground": "#e7e7e7",
        "titleBar.inactiveForeground": "#e7e7e799"
    },
    "peacock.favoriteColors": [
        {
            "name": "Angular Red",
            "value": "#b52e31"
        },
        {
            "name": "Auth0 Orange",
            "value": "#eb5424"
        },
        {
            "name": "Azure Blue",
            "value": "#007fff"
        },
        {
            "name": "C# Purple",
            "value": "#68217A"
        },
        {
            "name": "Gatsby Purple",
            "value": "#639"
        },
        {
            "name": "Go Cyan",
            "value": "#5dc9e2"
        },
        {
            "name": "Java Blue-Gray",
            "value": "#557c9b"
        },
        {
            "name": "JavaScript Yellow",
            "value": "#f9e64f"
        },
        {
            "name": "Mandalorian Blue",
            "value": "#1857a4"
        },
        {
            "name": "Node Green",
            "value": "#215732"
        },
        {
            "name": "React Blue",
            "value": "#00b3e6"
        },
        {
            "name": "Something Different",
            "value": "#832561"
        },
        {
            "name": "Vue Green",
            "value": "#42b883"
        }
    ],
    "window.titleBarStyle": "native",
    "window.title": "${rootName}",
    "bracketPairColorizer.consecutivePairColors": [
        "()",
        "[]",
        "{}",
        [
            "Red",
            "Green",
            "Blue"
        ],
        "Red"
    ],
    "editor.suggestSelection": "first",
    "vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
    "search.showLineNumbers": true,
    "launch": {
        "configurations": [],
        "compounds": []
    },
    "git.openRepositoryInParentFolders": "never",
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff"
    },
    "black-formatter.args": [
        "-C",
        "--line-length",
        "120"
    ],
    "python.analysis.diagnosticSeverityOverrides": {},
    "autopep8.args": [
        "-a",
        "--ignore=E402",
        "--max-line-length=120"
    ],
    "flake8.args": [
        "--ignore=E402",
        "--max-line-length=120"
    ],
    "workbench.preferredDarkColorTheme": "Monokai Dimmed",
    "window.zoomLevel": 1,
    "editor.mouseWheelZoom": true,
    "window.zoomPerWindow": false,
    "workbench.sideBar.location": "right",
    "files.autoSave": "afterDelay",
    "workbench.secondarySideBar.defaultVisibility": "hidden",
    "editor.fontSize": 16,
    "editor.formatOnSave": true,
    "python.defaultInterpreterPath": "/bin/python",
    "[python]": {
        "editor.defaultFormatter": "ms-python.black-formatte",
        "editor.formatOnSave": true,
        "editor.formatOnSaveMode": "file"
    },
    "yapf.args": [
        "--style",
        "{based_on_style: pep8, split_before_dot: true, join_multiple_lines: false}"
    ],
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.codeActionsOnSave": {
        "source.fixAll.ruff": "explicit",
        "source.organizeImports.ruff": "explicit"

    }
}
